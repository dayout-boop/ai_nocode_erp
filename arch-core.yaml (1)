# 15. LLM 평가·라우팅 3층 (★즉시·누적·주단위 — 무겁지 않게)
#     매 작동 변경=무겁다, 안변경=낡는다 → 층 분리. evaluator.py가 주단위 집계.
# ------------------------------------------------------------
llm_evaluation:
  principle: "평소 주단위 고정(가벼움) + 장애 즉시(안전) + 데이터 공짜(C-9 누적)"
  tier_immediate:                # 즉시층 — 명령마다, 양방향
    trigger: "에러·과부하·서비스 종료"
    action: "1~3차 재확인(리전 폴백→LLM 폴백) → 안되면 양방향 '지금 안됨' → 엔진 우회"
    bidirectional: "LLM→엔진(안됨 인지) ↔ 엔진→라우팅(다른 검증·리젠). healthcheck가 신호원"
    distinguish: "1~3차 재확인 = 일시장애(잠깐 429) vs 진짜종료(폐쇄) 구분"
    shutdown_rule: "★서비스 종료 감지 = 주 안 기다리고 즉시 순위서 제외"
  tier_accumulate:               # 누적층 — 실사용 기록, 순위변경 X
    data: "(언어·LLM·비용·에러율·정합성(crosscheck 통과율)·지연) → 평균 누적"
    source: "C-9 기록 파이프라인에 태그 추가 (기존 인프라 활용, 인위적 벤치 X)"
    rule: "매초 순위 안 바꿈, 평균값만 갱신 (관측·축적)"
  tier_weekly:                   # 고정층 — 주단위, 순위 확정
    period: "주 1회 (dayout 확정 — 너무 자주 X, 너무 드물게 X)"
    method: "누적 평균 + OpenRouter 시장데이터 교차 → 언어별 1~3위 재확정"
    openrouter: "★필수 — 우리가 안 써본 새 모델·가격변동(외부 기준). 내부 실사용 + 외부 시장 교차"
    output: "언어별 1~3위 우선순위 고정 → 그 주 동안 즉시층이 이 순위로 라우팅"
  score: "f(비용↓·에러율↓·정합성↑·지연↓). 가중치(비용vs품질vs속도)=dayout"
  impl: "evaluator.py(주단위 집계, 골격) + C-9 태그 + resolver 즉시층 + healthcheck 신호"
  status: "구조 동결. evaluator 골격만(인위적 벤치 X, 실사용 평균). 실제 OpenRouter 연동·구동 ⬜(S1~S2)"
