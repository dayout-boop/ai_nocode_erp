# ============================================================
# arch-core.yaml — 단일 진실(Single Source of Truth)
# ============================================================
# 이 파일 하나에서 (1) 에이전트가 듣는 규칙 (2) 게이트가 검사하는 규칙이 함께 나온다.
# 일꾼(에이전트)은 이 파일을 수정할 수 없다 (탬퍼-프루프, 보호 경로).
#
# 작동 모델: 병렬 일괄 → 결합 → L3b 교차검증(불일치만 탐지) → 틀린 소켓만 재명령
# 키값은 절대 여기 안 들어간다. 환경변수 "이름"만 참조. 실제 값은 .env / 시크릿매니저.
#
# 모델·가격 근거: 2026-06 실측 (SWE-bench Verified / 출력가 per 1M)
# ============================================================

meta:
  version: "0.2.0"
  updated: "2026-06-15"
  status: "에이전트 풀 연결성 5/5 검증 완료 (엔진 v0 healthcheck)"
  principle: "자체 LLM 없음. 뇌는 빌리고(에이전트), 오케스트레이션+검증 게이트는 직접."
  immutable: true   # 일꾼 수정 불가. 게이트만 갱신 가능(사람 승인).

# ------------------------------------------------------------
# 1. 에이전트 카탈로그 — 실제 제공자 + 구체 모델 + 키 환경변수 이름
#    (key_env = 환경변수 "이름"만. 값은 .env. git에 안 올라감)
#    status: verified(실측됨) / candidate(검증 후 투입)
# ------------------------------------------------------------
agents:

  # --- Python 평면 (Intelligence) : 자산 활용 ---
  manus_python:
    provider: manus
    model: manus-1.6              # REST API, taskMode=agent, agentProfile=quality
    api_base: "https://api.manus.ai/v1"          # .ai (.im은 문서사이트)
    auth_header: "API_KEY"        # Bearer 아님. 헤더 이름 그대로 API_KEY
    transport: "http2"            # ★ HTTP/1.1은 AWS ELB가 403. httpx(http2=True) 사용
    key_env: MANUS_API_KEY
    call_kind: manus              # orchestrator의 호출 분기 키
    status: verified              # 2026-06-15 실측: task 생성 HTTP 200 확인
    note: "월 110k 크레딧 자산. Python 평면 전담. POST /v1/tasks {prompt}."
    cost_hint: "~150 credit/task"
    project: "TRAYCER_ENGINE"
    project_id_env: MANUS_PROJECT_ID        # TFvPYz7kgWj247QbqgkB4r (Secrets 고정, 엔진 전용)
    task_id_management: "코드 자동 관리 (.manus_state.json). Secrets에 task_id 저장 안 함."
    task_id_init: "옵션A — 빈 상태로 시작, 첫 실행 때 create_task 자동 생성 후 파일 저장"
    healthcheck: "v2 GET /v2/task.detail (x-manus-api-key) — task 생성 없이 키검증"
    reuse_rule: "create는 1회. 이후 sendMessage로 같은 task에 이어감(맥락 유지). 500회마다 자동 순환·파일 갱신."

  # --- Go 평면 (Control) : 핵심 추론, 검증된 1순위 ---
  claude_go:
    provider: claude_code         # CLI, 실측으로 작동 확인됨
    model: claude-opus-4-8        # SWE-bench Verified 88.6% (하드코딩 최상위)
    key_env: ANTHROPIC_API_KEY    # 상시운영=API키 (구독OAuth는 3rd-party 약관위반)
    call_kind: claude_cli         # CLI 로그인 — REST 병렬 호출과 별도 처리
    status: verified
    note: "Go/SQL 핵심 추론·결합. 방금 실측: AGENTS.md 규격 준수 확인."
    cost_hint: "$5/$25 per 1M (in/out)"

  # --- Rust 평면 (Execution) : Go와 분리해 사용량 분산 (당신 지적) ---
  codex_rust:
    provider: codex               # OpenAI Codex CLI (Rust 바이너리), 로컬 기본=GPT-5.5
    model: gpt-5.5                # Terminal-Bench 2.1 83.4% (Claude 앞섬, 빠름)
    fallback_model: gpt-5.3-codex # 클라우드/코드리뷰용
    api_base: "https://api.openai.com/v1"
    key_env: OPENAI_API_KEY
    token_param: "max_completion_tokens"   # gpt-5.x는 max_tokens 불가
    call_kind: openai_compatible
    status: verified              # 2026-06-15 실측: chat.completions HTTP 200
    note: "Rust 컴파일·구현. Go(Claude)와 다른 에이전트로 사용량 분산."
    cost_hint: "gpt-5.5 $30/1M out / gpt-5.3-codex $14/1M out"

  # --- React 평면 (Frontend) ---
  cursor_react:
    provider: cursor              # Cursor Agent, 복수 파일 동시 편집
    model: auto                   # Cursor가 내부 라우팅 (Claude/GPT 혼합)
    api_base: "https://api.cursor.com"
    key_env: CURSOR_API_KEY
    call_kind: cursor             # Cloud Agent REST. v0=가용확인, repo작업은 비동기
    call_method: "Cloud Agent REST (api.cursor.com/v0/agents, Bearer). CLI(agent -p)는 TTY 필요"
    status: verified              # 2026-06-15 실측: GET /v1/me HTTP 200 (headless 작동)
    note: "React headless 자율구동 확인. CLI 대신 Cloud Agent REST 권장(TTY 회피)."

  gemini_react:                   # cursor 대안 (자율제어 확실)
    provider: gemini
    model: gemini-3.1-pro-preview # 대형 코드베이스·롱컨텍스트 강함 (preview 모델명)
    key_env: GEMINI_API_KEY
    call_kind: gemini
    status: verified              # 2026-06-15 실측: generateContent HTTP 200
    note: "Frontend 대안. 큰 코드베이스·1M 컨텍스트."

  # --- 저비용 대량 작업 (보일러플레이트·테스트생성·분석) ---
  cheap_bulk:
    provider: deepseek
    model: deepseek-v4-flash      # 출력 $0.28/1M = Opus의 ~1% 비용
    api_base: "https://api.deepseek.com"
    key_env: DEEPSEEK_API_KEY
    token_param: "max_tokens"
    call_kind: openai_compatible
    status: verified              # 2026-06-15 실측: OpenAI호환 chat HTTP 200
    note: "대량 단순작업(보일러플레이트·테스트·린트제안). 품질 게이트가 보장."
    cost_hint: "$0.14/$0.28 per 1M — 최저가"

  gemini_analysis:                # 대량 코드 분석·매핑 (Copilot Spaces 대체)
    provider: gemini
    model: gemini-3.1-pro-preview
    key_env: GEMINI_API_KEY
    call_kind: gemini
    status: verified
    note: "대량 소스 분석·컨텍스트 매핑. 1M 컨텍스트, Claude 대비 저비용."

# ------------------------------------------------------------
# 2. 평면 → 언어 → 에이전트 라우팅 (소켓 단위 병렬 분배)
#    난이도별 모델 라우팅: 핵심=프론티어, 대량=저비용
# ------------------------------------------------------------
planes:
  edge:          { lang: go,    agent: claude_go }
  control:       { lang: go,    agent: claude_go }
  execution:     { lang: rust,  agent: codex_rust }      # Go와 분리(분산)
  intelligence:  { lang: python, agent: manus_python }   # 110k 크레딧
  frontend:      { lang: react, agent: cursor_react }    # 검증됨. 대안 gemini_react

routing_by_difficulty:           # 정본 ⑥ 모델 라우팅
  frontier:   [claude_go, codex_rust]        # 복잡 추론·아키텍처 (5-10%)
  daily:      [claude_go, codex_rust]        # 함수·버그·테스트 (40-50%)
  bulk:       [cheap_bulk, gemini_analysis]  # 보일러·대량 (30-50%)

# ------------------------------------------------------------
# 3. ★ 계약(Contract) — 다중언어 일관성의 열쇠
#    병렬로 따로 짜도 이 계약을 기준 삼으면 맞물린다.
#    L3b가 "이 계약 위반"을 불일치로 탐지.
# ------------------------------------------------------------
contracts:
  inter_plane_protocol: grpc          # 평면 간 통신 = gRPC + 이벤트버스
  contract_dir: "contracts/"          # .proto 파일 단일 위치 (모든 평면이 참조)
  rule: "모든 평면 간 호출은 contracts/*.proto 시그니처를 따른다. 임의 인터페이스 금지."
  id_scheme: "semantic varchar, 접두사_nanoid"
  time: "UTC ms, bigint"
  money: "integer, 최소단위"
  ai_calls: "비동기, 핫패스 밖, L-5 게이트 경유"

# ------------------------------------------------------------
# 4. 절대 금지 (위반 = Critical 반려, 게이트가 차단)
# ------------------------------------------------------------
forbidden:
  db: [mysql, mysqlTable, sqlite, sqliteTable]      # PostgreSQL만
  api_stack: ["@trpc", createTRPCRouter]            # tRPC 금지
  pk: [autoincrement, serial, AUTO_INCREMENT]       # 의미적 varchar만
  money_type: [decimal, float, double]              # integer만
  time_store: ["Date()", timestamp_local]           # UTC ms bigint만
  secrets: ["평문 sk- 리터럴", "키값 하드코딩"]       # 환경변수/시크릿매니저만
  isolation: [BYPASSRLS, "tenant_id 없는 데이터 SQL"]
  learning: [self-learning, fine-tune, "online training"]
  runtime: [manus_runtime]                          # dogolf Manus 런타임 코드 사용 금지
                                                    # (단 Manus를 개발 도구로 쓰는 건 허용)

# ------------------------------------------------------------
# 5. 필수 (충족해야 통과)
# ------------------------------------------------------------
required:
  db: postgresql
  table: "단일 records(tenant_id, entity_type_id, id, data jsonb, created_at, updated_at)"
  isolation: "RLS 정책 + 앱레벨 tenant_id 주입 + 런타임 SET app.tenant_id"   # ← 테스트서 누락됐던 것 추가
  id_prefixes: [tenant_, org_, user_, role_, conn_, wf_, run_, secret_]
  connector_id: "conn_<능력>_<벤더>_v<주버전>"
  module_boundary: "공개 인터페이스(index)로만 통신. 내부 직접 import 금지."

# ------------------------------------------------------------
# 6. L3b 교차검증 규칙 (병렬 결합 후 "불일치만" 탐지)
#    R1~R3,R5 = Critical
# ------------------------------------------------------------
cross_check:
  R1_circular: "순환 의존 (A→B→A) = Critical"
  R2_layer: "레이어 역류 (domain→ui, execution→control 등) = Critical"
  R3_penetration: "내부 침투 (공개 인터페이스 우회 직접 import) = Critical"
  R5_unregistered: "module-registry 미등록 모듈 = Critical"
  R6_contract: "평면 간 호출이 contracts/*.proto 시그니처와 불일치 = Critical"  # 다중언어 핵심
  tools:
    typescript: dependency-cruiser
    python: import-linter
    rust: "cargo (의존 그래프)"
    go: "go mod / 정적분석"
    proto: "buf (계약 일치 검사)"

# ------------------------------------------------------------
# 6b. import 방향 규칙 (메인 §4.1-1 — 게이트B 구조검증용)
#    "어느 평면이 어느 평면을 import 가능한가" 방향 명시.
#    L3b가 역류(역방향 import)를 Critical로 차단.
# ------------------------------------------------------------
import_direction:
  edge:         [control]                    # edge는 control만
  control:      [execution, intelligence]    # control은 아래로
  execution:    [intelligence]               # execution은 intelligence만
  intelligence: []                           # 최하위, 위로 import 금지
  frontend:     [control]                    # frontend는 control(API)만
  rule: "위 목록 밖 import = R2 레이어 역류 = Critical. domain→ui 같은 역방향 금지."

# ------------------------------------------------------------
# 6c. 모듈 등록표 (메인 §4.1-2 — 게이트B R5 미등록 차단용)
#    여기 등록 안 된 모듈은 R5(미등록)로 Critical.
#    메인 코어 생산 시 이 목록을 채워야 게이트가 작동.
# ------------------------------------------------------------
module_registry:
  status: "스켈레톤 — 메인 코어 생산 단계에서 실제 모듈로 채움"
  example:
    - "edge/gateway"
    - "control/tenant"
    - "control/spec_registry"
    - "execution/workflow"
    - "intelligence/llm_gate"
  rule: "여기 없는 모듈을 코드가 생성/참조하면 R5 = Critical. 신규 모듈은 등록 먼저."

# ------------------------------------------------------------
# 6d. ★ 엔진 신뢰 경계 (메인 §4.2 — 소급 불가, 처음부터)
#    엔진(이 도구)은 런타임 아님. 메인 코어를 *생산*하는 L0 빌드 평면.
# ------------------------------------------------------------
engine_trust_boundary:
  layer: "L0 빌드 평면 — L1/L2/L3 어디에도 안 속하는 별도 경계"
  principle:
    - "엔진은 코어를 만드는 도구지 런타임이 아니다."
    - "엔진 산출물(코어 빌드 아티팩트)은 L3로 흐른다. 엔진 뚫리면 코어 뚫림 → 엔진도 L3급 통제."
    - "일꾼 LLM은 arch-core/게이트를 못 고침(탬퍼-프루프). 보호 경로 밖에서만 쓰기."
    - "엔진은 메인 레포 통째로 안 봄 — 작업 단위 컨텍스트만 핀셋 주입(L1 선별). IP 전체 노출 방지."
  provenance_note: "메인 코어를 외부 LLM으로 *생산*할 때만 origin-tag+hash 기록 필요(법적격리). 제품1 일반작업·현 엔진테스트엔 불필요(우리는 LLM 안 만듦, 코어생산 아님)."

# ------------------------------------------------------------
# 7. 검증·미세조정 (오타·결함 보완)
# ------------------------------------------------------------
verification:
  behavior: "샌드박스(E2B/Daytona)에서 빌드·테스트 (Go·Rust·Python 멀티런타임)"
  structure: "L3b cross_check (위 6번)"
  finetune: "Traycer 검증 코멘트 + 사람(Claude) 미세조정 — 싼 모델 오타 보완"
  gate_behavior: "HARD-BLOCK. Critical 1개라도 있으면 통과 불가 (Traycer는 코멘트뿐이라 우리가 차단)"
  # ★ 검증 2층 (5단계 토폴로지 분석 흡수 — 예제 아니라 명세로 박음)
  oracle_levels:
    L1_text: "텍스트 계약 검사 (crosscheck R1~R6, 빠른 1차 — 지금 구현됨)"
    L2_deterministic: "★샌드박스 실제 실행 → Exit Code 판정 (컴파일·린터·Playwright). 주관검증 금지. 미구현(인프라 S1)"
  verdict_rule: "Exit Code==0 통과 / !=0 자가치유. 'AI에게 잘 짰니' 묻기 금지 — 돌려서 판정."

# ------------------------------------------------------------
# 7b. 오케스트레이터 명세 (★다중분석 동결 — 예제 아니라 엔진 필수 명세)
#     5단계 파이프라인은 한 구현. 우리 필수 원칙만 박음 (하네스+비용강제+추상화).
# ------------------------------------------------------------
orchestrator_spec:
  paradigm: "sub-agent(평면별) + spec-driven(arch-core 영속) — ReAct 토큰폭주 회피"
  pipeline:                      # 5단계 (취할 원칙만)
    map: "AST 슬라이싱 + context pruning(read 76% 비용 절감) + Redis 캐싱"
    plan: "JSON Schema 강제(Structured Output) + 엣지별 동적 헌장(폭주 방지)"
    execute: "Late Binding fan-out → micro/heavy 동적(C-7 LOCK). 전건 VM 금지"
    heal: "결정론 오라클(Exit Code) + Temporal 영속(끊김 복구) + ★비용 상한"
    reduce: "Squash & Sync(내부 흡수→청정 1커밋) + Scale-to-Zero(유휴 0)"
  harness_first: "2026 정설 '에이전트→하네스'. 검증·감독(crosscheck·C-8)이 핵심, 흐름 아님"
  cost_enforcement:              # ★토큰 폭주 차단 (모든 자율루프 최대 함정)
    risk: "retry·context 누적으로 비용 3~7x 폭증 (Token Tsunami)"
    rule: "관측만으론 부족 → 실행 시점 강제. 호출 전 토큰예산 ceiling 차단"
    dual_cap: "MAX_RETRY(횟수) + 토큰예산(비용) 이중. 천장 초과=에스컬레이션"
    impl: "resolver.CreditGate를 비용 enforcement로 확장 (미구현, C-3 연계)"
  vendor_abstraction: "전부 Provider/Adapter 뒤 (추상화 유지). 단 벤더는 아래 infra_confirmed로 확정"
  status: "원칙 동결(이 명세). 구현: L1 crosscheck✅ / L2 오라클·비용강제·fan-out ⬜(S1~S2)"
  source: "「보강_5단계맵리듀스」「비판분석_5단계는예제일뿐」 — dayout 채택·수치 대기"

# ------------------------------------------------------------
# 7c. 확정 인프라 (★dayout LOCK — 이원화: 마스터 자가수정 / 글로벌 고객 SaaS)
#     Provider/Adapter 추상화 뒤에 들어갈 구체 벤더 확정. 추상화는 유지.
# ------------------------------------------------------------
infra_confirmed:
  mode_split: "분류1 마스터 24h 자가수정(내부 무인공장) / 분류2 글로벌 고객 SaaS(외부 상용)"
  core_runtime:
    vendor: "AWS EC2 (서울) 1 인스턴스 → Docker 2분리"
    master: "engine-master: config.env, 24h 자가수정 루프 전담"
    customer: "engine-customer-api: 가입·결제·API 분산처리 전담"
  database:                        # Store 소켓 — 3계층
    vendor: "Neon DB Pro (서버리스 브랜칭)"
